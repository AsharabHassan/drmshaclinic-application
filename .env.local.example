# Anthropic — used for the written skin analysis (Claude vision)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — used for the before/after image (gpt-image-2 edits endpoint)
OPENAI_API_KEY=sk-...

# GoHighLevel inbound webhook URL (Workflows -> Inbound Webhook trigger)
# Leads are POSTed here as JSON before results are revealed.
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/...

# Where the "Book a consultation" button sends users
NEXT_PUBLIC_BOOKING_URL=https://sironaaesthetics.co.uk

# Meta (Facebook) Pixel ID — used for PageView + Lead events and the
# Conversions API fields forwarded to GHL. Demo: leave unset/replace with the
# Sirona pixel before any real campaign.
NEXT_PUBLIC_META_PIXEL_ID=

# --- GoHighLevel v2 API — email the report PDF when a customer books ---
# Private Integration token (pit-...). NEVER commit the real value.
GHL_API_KEY=
# GHL sub-account (location) id
GHL_LOCATION_ID=
# Contact custom-field KEY that stores the report's media URL (used to write it)
GHL_REPORT_FIELD_KEY=facial_report_pdf
# Contact custom-field ID for the same field (used to read it back — GET returns
# customFields as {id, value} with no key). Find it once by writing the field via
# the API and reading the response, or in GHL's custom-field settings.
GHL_REPORT_FIELD_ID=
# Shared secret included in the GHL booking webhook URL (?key=...) so only GHL
# can trigger a send. Pick a long random string.
GHL_WEBHOOK_SECRET=
# Optional API base override (default: https://services.leadconnectorhq.com)
# GHL_API_BASE=https://services.leadconnectorhq.com
